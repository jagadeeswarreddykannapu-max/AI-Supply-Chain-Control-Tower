      "name": "Delivery Risk Engine"
    },
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const item = $json;\n\nconst transportRisk = item.Transportation_Risk || \"Low\";\nconst deliveryRisk = item.Delivery_Risk || \"Low\";\nconst priority = item.Delivery_Priority || \"Normal\";\n\nconst leadTime = Number(item.Lead_Time_Days || 0);\nconst stockoutDays = Number(item.Days_To_Stockout || 999);\n\nlet logisticsAction = \"\";\nlet transportMode = \"\";\nlet alternateTransport = \"\";\nlet routeStrategy = \"\";\nlet shipmentStrategy = \"\";\nlet inventoryStrategy = \"\";\nlet supplierStrategy = \"\";\nlet logisticsCost = \"\";\nlet deliverySpeed = \"\";\nlet businessImpact = \"\";\nlet executiveRecommendation = \"\";\n\n// =====================================================\n// CRITICAL\n// =====================================================\n\nif (transportRisk === \"Critical\" || deliveryRisk === \"Very High\") {\n\n    logisticsAction = \"Emergency Shipment\";\n\n    transportMode = \"Air Freight\";\n\n    alternateTransport = \"Express Road\";\n\n    routeStrategy = \"Direct Delivery\";\n\n    shipmentStrategy = \"Split Shipment\";\n\n    inventoryStrategy = \"Transfer inventory from nearest warehouse immediately.\";\n\n    supplierStrategy = \"Evaluate alternate supplier with shorter lead time.\";\n\n    logisticsCost = \"Very High\";\n\n    deliverySpeed = \"Fastest\";\n\n    businessImpact =\n    \"High probability of stockout, production disruption and customer service impact.\";\n\n    executiveRecommendation =\n    \"Use Air Freight for critical quantity. Transfer inventory from nearby warehouse while replenishment is in transit. Review alternate supplier for future orders.\";\n\n}\n\n// =====================================================\n// HIGH\n// =====================================================\n\nelse if (transportRisk === \"High\") {\n\n    logisticsAction = \"Priority Shipment\";\n\n    transportMode = \"Rail Freight\";\n\n    alternateTransport = \"Road Freight\";\n\n    routeStrategy = \"Regional Hub Routing\";\n\n    shipmentStrategy = \"Priority Shipment\";\n\n    inventoryStrategy = \"Increase safety stock if available.\";\n\n    supplierStrategy = \"Monitor supplier delivery performance.\";\n\n    logisticsCost = \"Medium\";\n\n    deliverySpeed = \"Fast\";\n\n    businessImpact =\n    \"Potential service level reduction if shipment is delayed.\";\n\n    executiveRecommendation =\n    \"Prioritize shipment and monitor supplier performance. Consider road transportation if rail capacity is unavailable.\";\n\n}\n\n// =====================================================\n// MEDIUM\n// =====================================================\n\nelse if (transportRisk === \"Medium\") {\n\n    logisticsAction = \"Monitor Shipment\";\n\n    transportMode = \"Road Freight\";\n\n    alternateTransport = \"Rail Freight\";\n\n    routeStrategy = \"Standard Route\";\n\n    shipmentStrategy = \"Consolidated Shipment\";\n\n    inventoryStrategy = \"Maintain current warehouse allocation.\";\n\n    supplierStrategy = \"Continue current supplier.\";\n\n    logisticsCost = \"Low\";\n\n    deliverySpeed = \"Normal\";\n\n    businessImpact =\n    \"Minor transportation risk.\";\n\n    executiveRecommendation =\n    \"Continue monitoring shipment. No immediate action required.\";\n\n}\n\n// =====================================================\n// LOW\n// =====================================================\n\nelse {\n\n    logisticsAction = \"Standard Transportation\";\n\n    transportMode = \"Sea Freight\";\n\n    alternateTransport = \"Road Freight\";\n\n    routeStrategy = \"Regular Schedule\";\n\n    shipmentStrategy = \"Consolidated Shipment\";\n\n    inventoryStrategy = \"Maintain inventory policy.\";\n\n    supplierStrategy = \"Continue current supplier.\";\n\n    logisticsCost = \"Lowest\";\n\n    deliverySpeed = \"Standard\";\n\n    businessImpact =\n    \"Transportation operating normally.\";\n\n    executiveRecommendation =\n    \"Continue planned transportation schedule.\";\n\n}\n\n// =====================================================\n// SMART BUSINESS RULES\n// =====================================================\n\n// Shipment may arrive after stock runs out\nif (stockoutDays < leadTime) {\n\n    executiveRecommendation +=\n    \" Shipment may arrive after inventory depletion. Escalate to logistics manager.\";\n\n}\n\n// Long supplier lead time\nif (leadTime > 20) {\n\n    supplierStrategy =\n    \"Recommend alternate supplier with lower lead time.\";\n\n}\n\n// Emergency priority\nif (priority === \"Emergency\") {\n\n    transportMode = \"Air Freight\";\n\n    shipmentStrategy = \"Split Shipment\";\n\n    logisticsCost = \"Highest\";\n\n}\n\n// =====================================================\n// OUTPUT\n// =====================================================\n\nitem.Logistics_Action = logisticsAction;\nitem.Transport_Mode = transportMode;\nitem.Alternate_Transport = alternateTransport;\nitem.Route_Strategy = routeStrategy;\nitem.Shipment_Strategy = shipmentStrategy;\nitem.Inventory_Strategy = inventoryStrategy;\nitem.Supplier_Strategy = supplierStrategy;\nitem.Logistics_Cost_Impact = logisticsCost;\nitem.Delivery_Speed = deliverySpeed;\nitem.Logistics_Business_Impact = businessImpact;\nitem.Executive_Recommendation = executiveRecommendation;\n\nreturn {\n    json: item\n};"
      },
