    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const item = $json;\n\nconst leadTime = Number(item.Lead_Time_Days || 0);\nconst daysToStockout = Number(item.Days_To_Stockout || 999);\nconst risk = item.Risk_Level || \"Low\";\nconst warehouse = item.Warehouse || \"\";\nconst supplier = item.Supplier || \"\";\n\nlet transportationRisk = \"\";\nlet deliveryPriority = \"\";\nlet shipmentStatus = \"\";\nlet logisticsScore = 100;\n\n// ===============================\n// Transportation Risk Assessment\n// ===============================\n\nif (risk === \"Critical\" || daysToStockout <= leadTime) {\n\n    transportationRisk = \"Critical\";\n    deliveryPriority = \"Emergency\";\n    shipmentStatus = \"Expedite Immediately\";\n    logisticsScore -= 50;\n\n}\nelse if (risk === \"High\" || daysToStockout <= (leadTime + 3)) {\n\n    transportationRisk = \"High\";\n    deliveryPriority = \"High\";\n    shipmentStatus = \"Priority Shipment\";\n    logisticsScore -= 30;\n\n}\nelse if (leadTime >= 20) {\n\n    transportationRisk = \"Medium\";\n    deliveryPriority = \"Medium\";\n    shipmentStatus = \"Monitor Transit\";\n    logisticsScore -= 15;\n\n}\nelse {\n\n    transportationRisk = \"Low\";\n    deliveryPriority = \"Normal\";\n    shipmentStatus = \"On Schedule\";\n\n}\n\n// =================================\n// Warehouse Adjustment\n// =================================\n\nif (warehouse.includes(\"Lyon\")) {\n    logisticsScore -= 5;\n}\n\nif (warehouse.includes(\"Marseille\")) {\n    logisticsScore -= 3;\n}\n\n// =================================\n// Supplier Adjustment\n// =================================\n\nif (supplier.includes(\"Supplier H\")) {\n    logisticsScore -= 10;\n}\n\nlogisticsScore = Math.max(0, Math.min(100, logisticsScore));\n\n// =================================\n// Output\n// =================================\n\nitem.Transportation_Risk = transportationRisk;\nitem.Delivery_Priority = deliveryPriority;\nitem.Shipment_Status = shipmentStatus;\nitem.Logistics_Health_Score = logisticsScore;\n\nreturn {\n    json: item\n};$input.item;"
      },
