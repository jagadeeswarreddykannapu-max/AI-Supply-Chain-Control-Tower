      "id": "040e25a1-e4a0-448f-9a88-765939d82250",
      "name": "Transportation Intelligence Engine"
    },
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const item = $json;\n\nconst leadTime = Number(item.Lead_Time_Days || 0);\nconst stockoutDays = Number(item.Days_To_Stockout || 999);\n\nconst transportRisk = item.Transportation_Risk || \"Low\";\nconst priority = item.Delivery_Priority || \"Normal\";\n\nlet deliveryRisk = \"\";\nlet estimatedDelay = \"\";\nlet reliability = \"\";\nlet logisticsStatus = \"\";\nlet score = 100;\n\n// =====================================\n// Delivery Risk Assessment\n// =====================================\n\nif (transportRisk === \"Critical\") {\n\n    deliveryRisk = \"Very High\";\n    estimatedDelay = \"High Probability\";\n    reliability = \"Poor\";\n    logisticsStatus = \"Critical\";\n    score -= 45;\n\n}\nelse if (transportRisk === \"High\") {\n\n    deliveryRisk = \"High\";\n    estimatedDelay = \"Possible\";\n    reliability = \"Moderate\";\n    logisticsStatus = \"Warning\";\n    score -= 30;\n\n}\nelse if (transportRisk === \"Medium\") {\n\n    deliveryRisk = \"Medium\";\n    estimatedDelay = \"Low\";\n    reliability = \"Good\";\n    logisticsStatus = \"Monitor\";\n    score -= 15;\n\n}\nelse {\n\n    deliveryRisk = \"Low\";\n    estimatedDelay = \"Very Low\";\n    reliability = \"Excellent\";\n    logisticsStatus = \"Healthy\";\n\n}\n\n// =====================================\n// Lead Time Adjustment\n// =====================================\n\nif (leadTime > 20)\n    score -= 10;\n\nif (stockoutDays < leadTime)\n    score -= 15;\n\n// =====================================\n// Priority Adjustment\n// =====================================\n\nif (priority === \"Emergency\")\n    score -= 15;\n\nelse if (priority === \"High\")\n    score -= 8;\n\n// =====================================\n// Final Score\n// =====================================\n\nscore = Math.max(0, Math.min(score, 100));\n\n// =====================================\n// Output\n// =====================================\n\nitem.Delivery_Risk = deliveryRisk;\nitem.Estimated_Delay = estimatedDelay;\nitem.Delivery_Reliability = reliability;\nitem.Logistics_Status = logisticsStatus;\nitem.Delivery_Health_Score = score;\n\nreturn {\n    json: item\n};"
      },
